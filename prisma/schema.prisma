generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Location {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imei      String
  sim       String?
  mobile    String
  lat       Float
  lng       Float
  city      String?
  ip        String?
  accuracy  Float?
  timestamp DateTime @default(now())
  userAgent String?
}

enum ShareSessionStatus {
  PENDING
  ACCEPTED
  DECLINED
  STOPPED
  EXPIRED
}

model ShareSession {
  id                     String             @id @default(auto()) @map("_id") @db.ObjectId
  ownerLabel             String
  recipientLabel         String?
  ownerToken             String             @unique
  recipientToken         String             @unique
  recipientDeviceId      String?
  recipientDeviceBoundAt DateTime?
  status                 ShareSessionStatus @default(PENDING)
  createdAt              DateTime           @default(now())
  acceptedAt             DateTime?
  stoppedAt              DateTime?
  expiresAt              DateTime
  pings                  LocationPing[]

  @@index([status, expiresAt])
}

model LocationPing {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  sessionId  String       @db.ObjectId
  session    ShareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  city       String?
  accuracy   Float?
  ip         String?
  userAgent  String?
  capturedAt DateTime     @default(now())

  @@index([sessionId, capturedAt])
}
